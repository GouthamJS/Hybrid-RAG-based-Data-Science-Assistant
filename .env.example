# LLM Provider
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here      # Free at console.groq.com
GROQ_MODEL=llama3-8b-8192

# Fallback (Offline)
OLLAMA_MODEL=mistral:7b
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings (no key needed — runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval Settings
TOP_K=5
RERANK_TOP_N=3
ENSEMBLE_DENSE_WEIGHT=0.6
ENSEMBLE_SPARSE_WEIGHT=0.4
CONFIDENCE_THRESHOLD=0.40

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Storage
VECTORDB_PATH=vectorstore/faiss_index
MEMORY_K=5
